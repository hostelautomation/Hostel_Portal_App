{
  "expo": {
    "name": "IIITDM-HMP",
    "slug": "IIITDM-HMP",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/iiitdm.png",
    "scheme": "iiitdmhmp",
    "userInterfaceStyle": "automatic",
    "extras": {
      "apiUrl": ""
    },
    "splash": {
      "image": "./src/assets/images/iiitdm.png",
      "resizeMode": "contain",
      "backgroundColor": "#08223a"
    },
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.iiitdm.hmpapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.iiitdm.hmpapp",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "categories": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "iiitdmhmp"
            }
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
